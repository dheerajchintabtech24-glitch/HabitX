<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="#1A1A1A"
    android:orientation="vertical"
    android:padding="12dp">

    <EditText
        android:id="@+id/exerciseNameEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@null"
        android:hint="Exercise Name (e.g. Bench Press)"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reps Done:"
            android:textColor="#BBBBBB"
            android:textSize="14sp" />

        <Button
            android:id="@+id/repMinusBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:backgroundTint="#333333"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text="-"
            android:textColor="#FFFFFF"
            app:cornerRadius="20dp" />

        <TextView
            android:id="@+id/repCountText"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0"
            android:textColor="#7B61FF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/repPlusBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:backgroundTint="#333333"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text="+"
            android:textColor="#FFFFFF"
            app:cornerRadius="20dp" />
            
        <ImageButton
            android:id="@+id/removeExerciseBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#FF4444" />
    </LinearLayout>
</LinearLayout>
