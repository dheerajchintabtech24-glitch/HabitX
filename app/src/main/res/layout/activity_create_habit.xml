<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create New Habit"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Customize your routine"
            android:textColor="#BBBBBB"
            android:textSize="16sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:hint="Habit Name"
            app:boxStrokeColor="#7B61FF"
            app:hintTextColor="#7B61FF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/habitNameEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Select Tracking Type"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/typeRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/radioTally"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tally Counter (e.g. Water, Reps)"
                android:textColor="#FFFFFF"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stopwatch Timer"
                android:textColor="#FFFFFF" />

            <RadioButton
                android:id="@+id/radioGoalTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Goal Countdown Timer"
                android:textColor="#FFFFFF" />

            <RadioButton
                android:id="@+id/radioAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Audio Recorder (e.g. Journaling, Practice)"
                android:textColor="#FFFFFF" />

            <RadioButton
                android:id="@+id/radioText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Text Log (e.g. Notes, Journal)"
                android:textColor="#FFFFFF" />

            <RadioButton
                android:id="@+id/radioPedometer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pedometer (Step Counter)"
                android:textColor="#FFFFFF" />

            <RadioButton
                android:id="@+id/radioImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Images (Gallery or Camera)"
                android:textColor="#FFFFFF" />
        </RadioGroup>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/saveHabitBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#7B61FF"
            android:text="Create Habit"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
