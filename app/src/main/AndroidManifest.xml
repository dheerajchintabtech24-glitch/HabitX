<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION"/>
    <application
        android:allowBackup="true"
        android:icon="@drawable/app_icon"
        android:roundIcon="@drawable/app_icon"
        android:label="HabitX"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <!-- 🔥 MAIN ENTRY -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- OTHER SCREENS -->
        <activity android:name=".SignupActivity" android:exported="false"/>
        <activity android:name=".HomeActivity" android:exported="false"/>
        <activity android:name=".ProgressActivity" android:exported="false"/>
        <activity android:name=".ProfileActivity" android:exported="false"/>
        <activity android:name=".CreateHabitActivity" android:exported="false"/>
        <activity android:name=".DynamicHabitActivity" android:exported="false"/>

        <activity android:name=".WalkingActivity" android:exported="false"/>
        <activity android:name=".MeditationActivity" android:exported="false"/>
        <activity android:name=".CookingActivity" android:exported="false"/>
        <activity android:name=".SleepActivity" android:exported="false"/>
        <activity android:name=".YogaActivity" android:exported="false"/>
        <activity android:name=".SwimmingActivity" android:exported="false"/>

    </application>

</manifest>